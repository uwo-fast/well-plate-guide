# Cross-platform line-ending policy.
# Store text with LF in Git so Windows and WSL clones stay stable.
* text=auto eol=lf

# Windows command files conventionally use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

